                }
            }
        },
        "dto.LoginAndRegisterRequest": {
            "type": "object",
            "required": [
                "email",
                "password"
            ],
            "properties": {
                "email": {
                    "type": "string"
                },
                "password": {
                    "type": "string",
                    "maxLength": 72,
                    "minLength": 8
                }
            }
        },
        "dto.TransferRequestDTO": {
            "type": "object",
            "properties": {
                "amount": {
                    "type": "integer"
                },
                "from_wallet_id": {
                    "type": "string"
                },
                "to_wallet_id": {
                    "type": "string"
                }
            }
        }
